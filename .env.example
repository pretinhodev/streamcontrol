# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="https://ais-pre-adhoe465ii347vo7prvivx-423361803818.us-west2.run.app"

# TWITCH_CLIENT_ID: Your Twitch Application Client ID
TWITCH_CLIENT_ID=""
# TWITCH_CLIENT_SECRET: Your Twitch Application Client Secret
TWITCH_CLIENT_SECRET=""

# KICK_CLIENT_ID: Your Kick Application Client ID (Since Kick is structured similarly to Twitch)
KICK_CLIENT_ID=""
# KICK_CLIENT_SECRET: Your Kick Application Client Secret
KICK_CLIENT_SECRET=""
# YOUTUBE_API_KEY: Your Google Cloud API Key with YouTube Data API v3 enabled
YOUTUBE_API_KEY=""

# Google/YouTube OAuth Credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_SESSION_SECRET=""
