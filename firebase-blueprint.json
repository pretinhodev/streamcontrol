{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about the registered user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "PlatformConnection": {
      "title": "Platform Connection",
      "description": "Details about a connected streaming platform.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["twitch", "youtube", "kick", "tiktok", "x", "manual"] },
        "name": { "type": "string" },
        "username": { "type": "string" },
        "avatar": { "type": "string" },
        "status": { "type": "string" },
        "accessToken": { "type": "string" },
        "refreshToken": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "type", "username"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles by UID"
    },
    "/users/{uid}/connections/{connectionId}": {
      "schema": "PlatformConnection",
      "description": "Connected platforms for a specific user"
    }
  }
}
